# === СЕКРЕТЫ БОТА ===

# Токен Telegram-бота (получить у @BotFather)
BOT_TOKEN=1234567890:ABCdefGhIjKlMnOpQrStUvWxYz

# === ВЛАДЕЛЕЦ ===

# Telegram ID владельца (получить у @userinfobot)
# Сюда вставлять свой ID!
OWNER_TELEGRAM_ID=123456789

# Номер телефона владельца (для Userbot — отслеживание подарков)
OWNER_PHONE=+79991234567

# API credentials владельца (получить на https://my.telegram.org)
OWNER_API_ID=12345678
OWNER_API_HASH=abcdef1234567890abcdef1234567890

# === САЙТ ===

# URL сайта (Vercel)
WEBSITE_URL=https://bothost.vercel.app

# === БЕЗОПАСНОСТЬ ===

# Секретный ключ для общения сайта и runner'а (придумайте свой!)
RUNNER_SECRET=very_secret_string_change_me

# === НАСТРОЙКИ ===

PORT=8000
BOTS_DIR=/app/user_bots
